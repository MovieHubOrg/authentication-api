    <changeSet author="Authentication" id="1774021542343-1">
        <createTable tableName="db_account">
            <column name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="db_accountPK"/>
            </column>
            <column name="kind" type="INT"/>
            <column name="username" type="VARCHAR(255)"/>
            <column name="phone" type="VARCHAR(255)"/>
            <column name="email" type="VARCHAR(255)"/>
            <column name="password" type="VARCHAR(255)"/>
            <column name="full_name" type="VARCHAR(255)"/>
            <column name="group_id" type="BIGINT"/>
            <column name="avatar_path" type="VARCHAR(255)"/>
            <column name="is_super_admin" type="BIT"/>
            <column name="created_by" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="created_date" type="datetime">
